{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(rg:*)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --quiet --project ~/.dotfiles/programs/ghostjar find-grep-guard",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "hegel-skill@hegeldev": true
  },
  "extraKnownMarketplaces": {
    "hegeldev": {
      "source": {
        "source": "github",
        "repo": "hegeldev/hegel-skill"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowWrite": [
        ".",
        "~/.buck",
        "~/.local/share/uv",
        "~/.cache/uv"
      ],
      "denyRead": [
        "~/"
      ],
      "allowRead": [
        ".",
        "/nix",
        "~/.nix-profile",
        "~/.local/state/nix",
        "~/.config/nix",
        "~/.buck"
      ]
    }
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
